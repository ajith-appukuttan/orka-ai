FROM node:22-slim
RUN apt-get update && apt-get install -y --no-install-recommends git ca-certificates && rm -rf /var/lib/apt/lists/*
RUN git config --global user.email "orka-builder@orka.ai" && git config --global user.name "Orka Builder"
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate
WORKDIR /app

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY packages/ ./packages/
COPY apps/agent-worker/package.json ./apps/agent-worker/
COPY apps/intake-api/package.json ./apps/intake-api/
RUN pnpm install --frozen-lockfile

COPY prompts/ ./prompts/
COPY apps/intake-api/ ./apps/intake-api/
COPY apps/agent-worker/ ./apps/agent-worker/

CMD ["pnpm", "--filter", "@orka/agent-worker", "dev"]
