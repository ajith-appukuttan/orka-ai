{
  "name": "@orka/intake-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "^0.16.0",
    "@apollo/server": "^4.11.0",
    "@graphql-tools/schema": "^10.0.0",
    "@orka/draft-schema": "workspace:*",
    "@orka/object-storage": "workspace:*",
    "@orka/shared-types": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "graphql": "^16.9.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-ws": "^5.16.0",
    "pg": "^8.13.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
