FROM node:22-slim

# System dependencies for Playwright Chromium
RUN apt-get update && apt-get install -y --no-install-recommends \
    libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxrandr2 libgbm1 \
    libpango-1.0-0 libcairo2 libasound2 libxshmfence1 libxfixes3 \
    fonts-liberation wget ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@9.15.4 --activate
WORKDIR /app

COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY tsconfig.base.json ./
COPY apps/preview-browser/package.json ./apps/preview-browser/

RUN pnpm install --frozen-lockfile 2>/dev/null || pnpm install

# Install Playwright Chromium via pnpm
RUN pnpm --filter @orka/preview-browser exec playwright install chromium || \
    ./node_modules/.bin/playwright install chromium || \
    echo "Playwright install skipped — Chrome launcher will use system Chrome"

# Point chromeLauncher.ts at Playwright's bundled Chromium
# Dynamically resolve the path so it survives Playwright version bumps
RUN CHROME_BIN=$(find /root/.cache/ms-playwright -name "chrome" -path "*/chrome-linux/*" 2>/dev/null | head -1) && \
    echo "CHROME_PATH=${CHROME_BIN}" >> /etc/environment && \
    ln -sf "${CHROME_BIN}" /usr/local/bin/chromium
ENV CHROME_PATH=/usr/local/bin/chromium

COPY apps/preview-browser/ ./apps/preview-browser/

EXPOSE 4002
CMD ["pnpm", "--filter", "@orka/preview-browser", "dev"]
